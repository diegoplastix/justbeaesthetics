or-element-9ffea4e e-con-full e-flex e-con e-child\" data-id=\"9ffea4e\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-1f4ea4b faq-box faq-1 elementor-widget elementor-widget-n-accordion\" data-id=\"1f4ea4b\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;default_state&quot;:&quot;expanded&quot;,&quot;max_items_expended&quot;:&quot;one&quot;,&quot;n_accordion_animation_duration&quot;:{&quot;unit&quot;:&quot;ms&quot;,&quot;size&quot;:400,&quot;sizes&quot;:[]}}\" data-widget_type=\"nested-accordion.default\">\n\t\t\t\t\t\t\t<div class=\"e-n-accordion\" aria-label=\"Accordion. Open links with Enter or Space, close with Escape, and navigate with Arrow Keys\">\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-3280\" class=\"e-n-accordion-item\" open>\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"1\" tabindex=\"0\" aria-expanded=\"true\" aria-controls=\"e-n-accordion-item-3280\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> What is the difference between what Dr. Marchuk does and a standard nutrition program? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-3280\" class=\"elementor-element elementor-element-ab71ef8 e-con-full e-flex e-con e-child\" data-id=\"ab71ef8\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-84190e2 elementor-widget elementor-widget-text-editor\" data-id=\"84190e2\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tMost nutrition programs give you a plan built around general guidelines. Dr. Marchuk builds around your specific biology, using blood type nutrition principles, CBC panels, and food allergen testing to identify what your body actually needs. Two people can follow the same plan and have completely different outcomes. Understanding your individual physiology is what makes the difference.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-3281\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"2\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-3281\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Do I need to come in for lab work before starting? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-3281\" class=\"elementor-element elementor-element-2150432 e-con-full e-flex e-con e-child\" data-id=\"2150432\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7140b6b elementor-widget elementor-widget-text-editor\" data-id=\"7140b6b\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tLab work is a core part of how the program works. A CBC panel and food allergen testing give Dr. Marchuk the data she needs to make informed recommendations rather than educated guesses. In most cases labs can be ordered following your initial consultation and reviewed together before your plan is finalized.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-3282\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"3\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-3282\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> What does a nutrition program at JustBE actually include? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-3282\" class=\"elementor-element elementor-element-0fc3984 e-con-full e-flex e-con e-child\" data-id=\"0fc3984\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-0f68f4f elementor-widget elementor-widget-text-editor\" data-id=\"0f68f4f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tIt starts with a deep-dive consultation covering your health history, lifestyle, current symptoms, and goals. From there, Dr. Marchuk develops a blood type nutrition protocol, reviews your lab results, and builds a personalized plan that addresses food, sleep, hormones, stress, and exercise together. Ongoing coaching and adjustments are included throughout.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-3283\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"4\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-3283\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Can I do the nutrition program if I live outside Dallas? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-3283\" class=\"elementor-element elementor-element-74ceb3a e-con-full e-flex e-con e-child\" data-id=\"74ceb3a\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-3261678 elementor-widget elementor-widget-text-editor\" data-id=\"3261678\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tYes. Consultations, coaching sessions, lab result reviews, and program adjustments are all available via telehealth. The initial consultation and any in-office lab draws may require an in-person visit, but the ongoing program can run entirely virtually for clients who prefer it.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-3284\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"5\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-3284\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> How long before I start seeing results? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-3284\" class=\"elementor-element elementor-element-59b606a e-con-full e-flex e-con e-child\" data-id=\"59b606a\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-89bd7e3 elementor-widget elementor-widget-text-editor\" data-id=\"89bd7e3\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tMost clients begin noticing meaningful shifts in energy, digestion, and overall wellbeing within the first four to six weeks as dietary changes take effect and deficiencies are addressed. Deeper metabolic and hormonal changes typically become more apparent over three months. This is a program built for lasting results, not a quick fix.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-ce6655c faq-box faq-2 elementor-widget elementor-widget-n-accordion\" data-id=\"ce6655c\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;default_state&quot;:&quot;expanded&quot;,&quot;max_items_expended&quot;:&quot;one&quot;,&quot;n_accordion_animation_duration&quot;:{&quot;unit&quot;:&quot;ms&quot;,&quot;size&quot;:400,&quot;sizes&quot;:[]}}\" data-widget_type=\"nested-accordion.default\">\n\t\t\t\t\t\t\t<div class=\"e-n-accordion\" aria-label=\"Accordion. Open links with Enter or Space, close with Escape, and navigate with Arrow Keys\">\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2160\" class=\"e-n-accordion-item\" open>\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"1\" tabindex=\"0\" aria-expanded=\"true\" aria-controls=\"e-n-accordion-item-2160\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> What aesthetic treatments does JustBE offer? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2160\" class=\"elementor-element elementor-element-cc7900e e-con-full e-flex e-con e-child\" data-id=\"cc7900e\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-d17881a elementor-widget elementor-widget-text-editor\" data-id=\"d17881a\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tJustBE offers Botox and lip filler, both administered exclusively by Dr. Marchuk. These are the only aesthetic services currently available. Every treatment is approached conservatively and with your overall health in mind, not as a standalone procedure sold by volume.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2161\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"2\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2161\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Do I need to be a wellness client to book Botox or lip filler? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2161\" class=\"elementor-element elementor-element-15edbc1 e-con-full e-flex e-con e-child\" data-id=\"15edbc1\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-b5eddee elementor-widget elementor-widget-text-editor\" data-id=\"b5eddee\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tNo. Aesthetic treatments are available as standalone services. That said, Dr. Marchuk may ask questions about your overall health during your consultation because understanding the full picture helps her make better treatment decisions. You are never required to add services you did not come in for.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2162\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"3\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2162\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> How is Botox at JustBE different from a typical medspa? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2162\" class=\"elementor-element elementor-element-f111462 e-con-full e-flex e-con e-child\" data-id=\"f111462\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-f71b148 elementor-widget elementor-widget-text-editor\" data-id=\"f71b148\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tEvery treatment is administered by Dr. Marchuk directly, every time. No nurses, no rotating injectors, no rushed appointments. The approach here is conservative and anatomy-driven, with the goal of a result that looks like you on a well-rested day, not a visibly treated version of you.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2163\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"4\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2163\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> How long do results from Botox and lip filler last? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2163\" class=\"elementor-element elementor-element-735bd34 e-con-full e-flex e-con e-child\" data-id=\"735bd34\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-b60de98 elementor-widget elementor-widget-text-editor\" data-id=\"b60de98\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tBotox typically lasts three to four months. Lip filler results vary between six and twelve months depending on the product used and how your body processes hyaluronic acid. Clients engaged in a nutrition or wellness program often report longer-lasting aesthetic results due to the overall improvement in their health foundation.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2164\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"5\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2164\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> What should I expect at my first aesthetic appointment? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2164\" class=\"elementor-element elementor-element-c5b4870 e-con-full e-flex e-con e-child\" data-id=\"c5b4870\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-49c1609 elementor-widget elementor-widget-text-editor\" data-id=\"49c1609\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tEvery appointment begins with a consultation. Dr. Marchuk reviews your goals, evaluates your anatomy, and explains exactly what she is recommending and why before anything is administered. There is no pressure and no upselling. If a treatment is not right for you, she will tell you.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-cc11ba9 faq-box faq-3 elementor-widget elementor-widget-n-accordion\" data-id=\"cc11ba9\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;default_state&quot;:&quot;expanded&quot;,&quot;max_items_expended&quot;:&quot;one&quot;,&quot;n_accordion_animation_duration&quot;:{&quot;unit&quot;:&quot;ms&quot;,&quot;size&quot;:400,&quot;sizes&quot;:[]}}\" data-widget_type=\"nested-accordion.default\">\n\t\t\t\t\t\t\t<div class=\"e-n-accordion\" aria-label=\"Accordion. Open links with Enter or Space, close with Escape, and navigate with Arrow Keys\">\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2130\" class=\"e-n-accordion-item\" open>\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"1\" tabindex=\"0\" aria-expanded=\"true\" aria-controls=\"e-n-accordion-item-2130\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> What services are available via telehealth? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2130\" class=\"elementor-element elementor-element-7d3aad1 e-con-full e-flex e-con e-child\" data-id=\"7d3aad1\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-c70003d elementor-widget elementor-widget-text-editor\" data-id=\"c70003d\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tWellness consultations, nutrition coaching, medical weight loss check-ins, peptide therapy follow-ups, and lab result reviews are all available virtually. Botox and lip filler require an in-person appointment at the Dallas clinic.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2131\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"2\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2131\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Is telehealth available to clients outside of Texas? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2131\" class=\"elementor-element elementor-element-d73d4b2 e-con-full e-flex e-con e-child\" data-id=\"d73d4b2\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-a0ea9c6 elementor-widget elementor-widget-text-editor\" data-id=\"a0ea9c6\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tCurrently Dr. Marchuk sees telehealth clients within Texas. If you are located outside the state, reach out directly and we will let you know what options are available to you.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2132\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"3\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2132\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> How do appointments work and how often will I be seen? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2132\" class=\"elementor-element elementor-element-2a97cab e-con-full e-flex e-con e-child\" data-id=\"2a97cab\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-f4fdc08 elementor-widget elementor-widget-text-editor\" data-id=\"f4fdc08\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tAppointment frequency depends on your program. Medical weight loss clients typically check in monthly or bi-weekly depending on where they are in their protocol. Nutrition and wellness clients schedule based on their individual plan. Dr. Marchuk reviews each case and recommends a cadence that supports your specific goals.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2133\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"4\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2133\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Can I get a prescription through a telehealth visit? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span class='e-opened' ><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><\/svg><\/span>\n\t\t\t<span class='e-closed'><svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"22\" height=\"24\" viewBox=\"0 0 22 24\" fill=\"none\"><path d=\"M18.5625 12.3125C18.9422 12.3125 19.25 12.6203 19.25 13C19.25 13.3797 18.9422 13.6875 18.5625 13.6875H3.4375C3.0578 13.6875 2.75 13.3797 2.75 13C2.75 12.6203 3.0578 12.3125 3.4375 12.3125H18.5625Z\" fill=\"#555555\"><\/path><path d=\"M10.3125 20.5625V5.4375C10.3125 5.0578 10.6203 4.75 11 4.75C11.3797 4.75 11.6875 5.0578 11.6875 5.4375V20.5625C11.6875 20.9422 11.3797 21.25 11 21.25C10.6203 21.25 10.3125 20.9422 10.3125 20.5625Z\" fill=\"#1A2530\"><\/path><\/svg><\/span>\n\t\t<\/span>\n\n\t\t\t\t\t\t<\/summary>\n\t\t\t\t<div role=\"region\" aria-labelledby=\"e-n-accordion-item-2133\" class=\"elementor-element elementor-element-7614043 e-con-full e-flex e-con e-child\" data-id=\"7614043\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-95bc022 elementor-widget elementor-widget-text-editor\" data-id=\"95bc022\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\tIn many cases, yes. Prescriptions for weight loss protocols, peptide therapy, and other programs can be issued following a telehealth consultation, provided Dr. Marchuk has your full health history and relevant lab work on file. Medications and peptides are dispensed through licensed pharmacies and shipped directly to your door.\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/details>\n\t\t\t\t\t\t<details id=\"e-n-accordion-item-2134\" class=\"e-n-accordion-item\" >\n\t\t\t\t<summary class=\"e-n-accordion-item-title\" data-accordion-index=\"5\" tabindex=\"-1\" aria-expanded=\"false\" aria-controls=\"e-n-accordion-item-2134\" >\n\t\t\t\t\t<span class='e-n-accordion-item-title-header'><div class=\"e-n-accordion-item-title-text\"> Does Dr. Marchuk see every client personally? <\/div><\/span>\n\t\t\t\t\t\t\t<span class='e-n-accordion-item-title-icon'>\n\t\t\t<span cl